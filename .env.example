# Copy to `.env` on each device and fill machine-specific values.

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Local PostgreSQL settings used by Flyway and Spring Boot.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diagnostic_ai
DB_USER=diagnostic
DB_PASSWORD=diagnostic

# Docker log discovery settings.
DOCKER_PROJECT_LABEL=ai.project.env
DOCKER_PROJECT_LABEL_VALUE=demo
DOCKER_LOGS_TAIL=200

# Gemini settings.
# Create the key in Google AI Studio: https://ai.google.dev/aistudio
# Then paste it into GEMINI_API_KEY below.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PROMPT_VERSION=v1
