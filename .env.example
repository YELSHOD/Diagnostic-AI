# Copy to `.env` on each device and fill machine-specific values.

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Local PostgreSQL settings used by Flyway and Spring Boot when you run from IntelliJ.
# If your installed PostgreSQL uses a different user/password, change these values in `.env`.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diagnostic_ai
DB_USER=diagnostic
DB_PASSWORD=diagnostic

# Local log file used by the backend in `dev` profile.
APP_LOG_FILE=./logs/diagnosticserviceai.log

# Docker log discovery settings.
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_PROJECT_LABEL=ai.project.env
DOCKER_PROJECT_LABEL_VALUE=demo
DOCKER_LOGS_TAIL=200

# Gemini settings.
# Create the key in Google AI Studio: https://ai.google.dev/aistudio
# Then paste it into GEMINI_API_KEY in your local `.env` or IntelliJ run config.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PROMPT_VERSION=v1
